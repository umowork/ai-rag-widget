# ──────────────────────────────────────────────────────
# AI RAG Widget — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────

# ─── LLM Provider ────────────────────────────────────
# Options: openai | yandexgpt | mock
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# YandexGPT
YANDEXGPT_API_KEY=your-yandexgpt-api-key
YANDEXGPT_FOLDER_ID=your-yandex-cloud-folder-id
YANDEXGPT_MODEL=yandexgpt-lite

# ─── Embedding Provider ─────────────────────────────
# Options: huggingface | openai
EMBEDDING_PROVIDER=huggingface

# For HuggingFace (default: free, no API key needed)
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# For OpenAI embeddings (requires OPENAI_API_KEY)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ─── Vector Store ───────────────────────────────────
CHROMA_DB_DIR=./chroma_db
CHROMA_COLLECTION=rag_docs

# ─── Document Processing ────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── Search ─────────────────────────────────────────
TOP_K=4
RERANK=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ─── Cache ──────────────────────────────────────────
CACHE_TTL=300
CACHE_MAX_SIZE=128

# ─── Mode ───────────────────────────────────────────
# Set to "true" to use mock LLM (no API key needed)
MOCK_MODE=false
DEBUG=false

# ─── Server ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# ─── Uploads ────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
